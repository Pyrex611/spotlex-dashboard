<file path="app/equipments/page.tsx">
"use client"

import { useEffect, useState } from 'react';
import Link from 'next/link';
import { Plus, Upload, Image as ImageIcon } from 'lucide-react';
import { bulkUploadCSV } from '@/lib/actions';
import Papa from 'papaparse';

export default function EquipmentsPage() {
  const[equipments, setEquipments] = useState<any[]>([]);

  useEffect(() => {
    fetch('/api/equipments').then(r => r.json()).then(setEquipments);
  },[]);

  const handleBulkUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      Papa.parse(file, {
        header: true,
        complete: async (results) => {
          await bulkUploadCSV(results.data);
          window.location.reload();
        }
      });
    }
  };

  return (
    <div className="max-w-5xl mx-auto">
      <div className="mb-8">
        <h1 className="text-3xl font-bold text-green-900">Equipment Registry</h1>
        <p className="text-green-700 mt-2">Manage tools and machinery.</p>
      </div>

      <ul className="space-y-4">
        {/* Top Add Item Row */}
        <li className="flex items-center justify-between gap-4 h-24">
          <Link href="/equipments/new" className="flex-1 flex items-center h-full bg-white border-2 border-dashed border-green-300 rounded-2xl hover:bg-green-50 transition p-4 cursor-pointer">
            <div className="w-16 h-16 rounded-xl bg-green-100 flex-shrink-0 flex items-center justify-center mr-6">
              <Plus size={32} className="text-green-600" />
            </div>
            <span className="text-lg font-bold text-green-700">Add a new equipment</span>
          </Link>
          <label className="w-24 h-full bg-green-700 hover:bg-green-800 text-white rounded-2xl flex flex-col items-center justify-center cursor-pointer shadow-md transition-colors">
            <Upload size={28} className="mb-1" />
            <span className="text-[10px] font-bold tracking-widest uppercase">CSV / XLSX</span>
            <input type="file" accept=".csv" className="hidden" onChange={handleBulkUpload} />
          </label>
        </li>

        {/* Equipment List */}
        {equipments.map(eq => (
          <li key={eq.id}>
            <Link href={`/equipments/${eq.id}`} className="flex items-center h-28 bg-white border border-green-100 shadow-sm hover:shadow-md rounded-2xl p-4 transition-all group">
              <div className="w-20 h-20 rounded-xl bg-green-50 border border-green-100 flex-shrink-0 mr-6 overflow-hidden flex items-center justify-center">
                {eq.picture ? (
                   <img src={eq.picture} alt={eq.name} className="w-full h-full object-cover" />
                ) : (
                   <ImageIcon size={32} className="text-green-300" />
                )}
              </div>
              <div className="flex-1">
                <h3 className="text-xl font-bold text-green-900 group-hover:text-green-700 transition">{eq.name || 'Component'}</h3>
                <div className="mt-2 flex items-center gap-3">
                  <span className="text-sm font-mono bg-green-100 text-green-800 px-3 py-1 rounded-md">{eq.code || eq.componentCode}</span>
                  <span className="text-xs uppercase tracking-wider font-bold text-gray-500">{eq.type || (eq.componentCode ? 'COMPONENT' : 'MAIN')}</span>
                </div>
              </div>
            </Link>
          </li>
        ))}
      </ul>
    </div>
  );
}
