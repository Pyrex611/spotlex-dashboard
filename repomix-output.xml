"use client"

import { useEffect, useState } from 'react';
import { endProject } from '@/lib/actions';
import { CheckSquare, Square, AlertTriangle } from 'lucide-react';
import { format } from 'date-fns';

export default function ProjectDetails({ params }: { params: { id: string } }) {
  const [project, setProject] = useState<any>(null);
  const [modalOpen, setModalOpen] = useState(false);
  const[warningOpen, setWarningOpen] = useState(false);
  
  const [endedBy, setEndedBy] = useState('');
  const [checkedEq, setCheckedEq] = useState<Record<string, boolean>>({});

  useEffect(() => {
    fetch(`/api/projects/${params.id}`).then(r => r.json()).then(setProject);
  }, [params.id]);

  if (!project) return <div className="p-8 text-center text-green-700 animate-pulse">Loading project details...</div>;

  const handleEndInitiate = () => {
    const initialChecks: any = {};
    project.equipment.forEach((e: any) => initialChecks[e.equipment.id] = false);
    setCheckedEq(initialChecks);
    setModalOpen(true);
  };

  const handleEndSubmit = async () => {
    const total = project.equipment.length;
    const checkedCount = Object.values(checkedEq).filter(Boolean).length;

    if (checkedCount < total && !warningOpen) {
      setWarningOpen(true);
      return;
    }
    
    const returnedIds = Object.keys(checkedEq).filter(k => checkedEq[k]);
    await endProject(project.id, endedBy, returnedIds);
  };

  return (
    <div className="max-w-4xl mx-auto space-y-6">
      <div className="bg-white p-8 rounded-3xl shadow-sm border border-green-100">
        <div className="flex justify-between items-start mb-6">
          <div>
            <h1 className="text-3xl font-extrabold text-green-900">{project.name}</h1>
            <p className="text-green-600 mt-1">Started on {format(new Date(project.startDate), 'MMMM dd, yyyy')}</p>
          </div>
          <span className={`px-4 py-1.5 rounded-full text-sm font-bold tracking-wide ${project.status === 'ONGOING' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-700'}`}>
            {project.status}
          </span>
        </div>

        <div className="grid md:grid-cols-2 gap-8 mt-8">
          <div>
            <h3 className="text-sm uppercase tracking-widest text-green-400 font-bold mb-4">Assigned Employees</h3>
            <ul className="space-y-2">
              {project.employees.map((emp: any) => (
                <li key={emp.id} className="bg-green-50/50 p-3 rounded-xl text-green-900 font-medium border border-green-50">{emp.name}</li>
              ))}
            </ul>
          </div>
          <div>
            <h3 className="text-sm uppercase tracking-widest text-green-400 font-bold mb-4">Assigned Equipment</h3>
            <ul className="space-y-2">
              {project.equipment.map((eq: any) => (
                <li key={eq.id} className="bg-green-50/50 p-3 rounded-xl text-green-900 font-medium flex justify-between border border-green-50">
                  <span>{eq.equipment.name}</span>
                  <span className="font-mono text-xs text-green-600 bg-white px-2 py-1 rounded shadow-sm">{eq.equipment.code}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        {project.status === 'ONGOING' && (
          <div className="mt-10 border-t border-green-100 pt-8 flex justify-end">
            <button onClick={handleEndInitiate} className="bg-red-50 text-red-600 hover:bg-red-600 hover:text-white border border-red-200 px-8 py-3 rounded-xl font-bold transition-all shadow-sm">
              End Project
            </button>
          </div>
        )}
      </div>

      {/* End Project Modal */}
      {modalOpen && (
        <div className="fixed inset-0 bg-green-950/40 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
          <div className="bg-white p-8 rounded-3xl w-full max-w-lg shadow-2xl relative">
            {!warningOpen ? (
              <>
                <h2 className="text-2xl font-bold text-green-900 mb-6 border-b pb-4">End Project Checklist</h2>
                <div className="space-y-3 max-h-60 overflow-y-auto mb-6 pr-2">
                  {project.equipment.map((eq: any) => (
                    <div key={eq.equipment.id} className="flex items-center justify-between p-3 bg-green-50 rounded-xl cursor-pointer hover:bg-green-100 transition" onClick={() => setCheckedEq({ ...checkedEq, [eq.equipment.id]: !checkedEq[eq.equipment.id] })}>
                      <div>
                        <p className="font-semibold text-green-900">{eq.equipment.name}</p>
                        <p className="text-xs font-mono text-green-600">{eq.equipment.code}</p>
                      </div>
                      {checkedEq[eq.equipment.id] ? <CheckSquare className="text-green-600" size={24} /> : <Square className="text-green-300" size={24} />}
                    </div>
                  ))}
                </div>
                <div className="mb-6">
                  <label className="block text-sm font-semibold text-green-800 mb-2">Name of person ending project</label>
                  <input required value={endedBy} onChange={e => setEndedBy(e.target.value)} className="w-full border-green-200 focus:ring-green-600 rounded-xl p-3 bg-white border" placeholder="Enter your full name" />
                </div>
                <div className="flex gap-4">
                  <button onClick={() => setModalOpen(false)} className="flex-1 bg-gray-100 text-gray-700 py-3 rounded-xl font-bold">Cancel</button>
                  <button onClick={handleEndSubmit} disabled={!endedBy} className="flex-1 bg-green-700 text-white py-3 rounded-xl font-bold hover:bg-green-800 disabled:opacity-50">End Project</button>
                </div>
              </>
            ) : (
              <div className="text-center py-6">
                <AlertTriangle size={64} className="text-orange-500 mx-auto mb-4" />
                <h3 className="text-xl font-bold text-green-900 mb-2">Not all Equipment has been confirmed</h3>
                <p className="text-gray-600 mb-8">Some equipment assigned to this project was not ticked as returned. Are you sure you want to end the project?</p>
                <div className="flex gap-4">
                  <button onClick={() => setWarningOpen(false)} className="flex-1 bg-gray-100 text-gray-700 py-3 rounded-xl font-bold">No, go back</button>
                  <button onClick={handleEndSubmit} className="flex-1 bg-red-600 text-white py-3 rounded-xl font-bold hover:bg-red-700">Yes, end project</button>
                </div>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
