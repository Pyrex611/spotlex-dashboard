"use client"

import { useEffect, useState } from 'react';
import { updateEquipment } from '@/lib/actions';
import { ImageIcon } from 'lucide-react';

export default function EditEquipment({ params }: { params: { id: string } }) {
  const [eq, setEq] = useState<any>(null);
  const[editMode, setEditMode] = useState(false);

  useEffect(() => {
    fetch('/api/equipments').then(r => r.json()).then(data => {
      setEq(data.find((item: any) => item.id === params.id));
    });
  }, [params.id]);

  if (!eq) return <div className="p-8 text-center text-green-700">Loading...</div>;

  const handleImage = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      const reader = new FileReader();
      reader.onloadend = () => setEq({ ...eq, picture: reader.result });
      reader.readAsDataURL(file);
    }
  };

  return (
    <div className="max-w-xl mx-auto bg-white p-8 rounded-3xl shadow-sm border border-green-100">
      <div className="flex flex-col items-center mb-8">
        <div className="w-32 h-32 rounded-2xl bg-green-50 border-2 border-green-100 overflow-hidden mb-4 flex justify-center items-center">
          {eq.picture ? <img src={eq.picture} className="w-full h-full object-cover" /> : <ImageIcon size={48} className="text-green-200" />}
        </div>
        <h1 className="text-2xl font-bold text-green-900">{eq.name || 'Component'}</h1>
        <span className="font-mono text-green-600 bg-green-50 px-3 py-1 rounded-md mt-2">{eq.code || eq.componentCode}</span>
      </div>

      {editMode ? (
        <form action={() => { updateEquipment(eq.id, { name: eq.name, code: eq.code, picture: eq.picture }); setEditMode(false); }} className="space-y-6 border-t border-green-50 pt-6">
          <div>
            <label className="block text-sm font-semibold text-green-800 mb-2">Name</label>
            <input value={eq.name || ''} onChange={e => setEq({...eq, name: e.target.value})} className="w-full border border-green-200 rounded-xl p-3 bg-white" />
          </div>
          <div>
            <label className="block text-sm font-semibold text-green-800 mb-2">Code</label>
            <input value={eq.code || ''} onChange={e => setEq({...eq, code: e.target.value})} className="w-full border border-green-200 rounded-xl p-3 bg-white" />
          </div>
          <div>
            <label className="block text-sm font-semibold text-green-800 mb-2">Update Picture</label>
            <input type="file" accept="image/*" onChange={handleImage} />
          </div>
          <button type="submit" className="w-full bg-green-700 text-white py-3 rounded-xl font-bold hover:bg-green-800">Save Changes</button>
        </form>
      ) : (
        <div className="border-t border-green-50 pt-6 mt-4">
          <button onClick={() => setEditMode(true)} className="w-full bg-green-100 text-green-800 py-3 rounded-xl font-bold hover:bg-green-200 transition">
            Edit Equipment Info
          </button>
        </div>
      )}
    </div>
  );
}
</file>

