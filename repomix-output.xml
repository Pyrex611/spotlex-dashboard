"use client"

import { useState } from 'react';
import { createEquipment } from '@/lib/actions';
import { ImageIcon } from 'lucide-react';

export default function NewEquipment() {
  const [type, setType] = useState('MAIN');
  const [name, setName] = useState('');
  const [code, setCode] = useState('');
  const [compCode, setCompCode] = useState('');
  const [equipCode, setEquipCode] = useState('');
  const [picture, setPicture] = useState('');

  const handleImage = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      const reader = new FileReader();
      reader.onloadend = () => setPicture(reader.result as string);
      reader.readAsDataURL(file);
    }
  };

  return (
    <div className="max-w-xl mx-auto bg-white p-8 rounded-3xl shadow-sm border border-green-100">
      <h1 className="text-2xl font-bold text-green-900 mb-6">Register Equipment</h1>
      
      <form action={() => createEquipment({ type, name, code, componentCode: compCode, equipmentCode: equipCode, picture })} className="space-y-6">
        <div>
          <label className="block text-sm font-semibold text-green-800 mb-2">Equipment Type</label>
          <select value={type} onChange={e => setType(e.target.value)} className="w-full border-green-200 focus:ring-green-600 rounded-xl p-3 bg-green-50 border">
            <option value="MAIN">Main Equipment</option>
            <option value="COMPONENT">Equipment Component</option>
          </select>
        </div>

        {type === 'MAIN' ? (
          <>
            <div>
              <label className="block text-sm font-semibold text-green-800 mb-2">Equipment Name</label>
              <input required value={name} onChange={e => setName(e.target.value)} className="w-full border-green-200 focus:ring-green-600 rounded-xl p-3 bg-green-50 border" />
            </div>
            <div>
              <label className="block text-sm font-semibold text-green-800 mb-2">Equipment Code</label>
              <input required value={code} onChange={e => setCode(e.target.value)} className="w-full border-green-200 focus:ring-green-600 rounded-xl p-3 bg-green-50 border" />
            </div>
          </>
        ) : (
          <>
            <div>
              <label className="block text-sm font-semibold text-green-800 mb-2">Component Code</label>
              <input required value={compCode} onChange={e => setCompCode(e.target.value)} className="w-full border-green-200 focus:ring-green-600 rounded-xl p-3 bg-green-50 border" />
            </div>
            <div>
              <label className="block text-sm font-semibold text-green-800 mb-2">Linked Equipment Code</label>
              <input required value={equipCode} onChange={e => setEquipCode(e.target.value)} className="w-full border-green-200 focus:ring-green-600 rounded-xl p-3 bg-green-50 border" />
            </div>
          </>
        )}

        <div>
          <label className="block text-sm font-semibold text-green-800 mb-2">Picture (Optional)</label>
          <div className="flex items-center gap-4">
            {picture ? (
              <img src={picture} alt="Preview" className="w-20 h-20 rounded-xl object-cover border border-green-200" />
            ) : (
              <div className="w-20 h-20 rounded-xl bg-green-50 flex items-center justify-center border border-green-200"><ImageIcon className="text-green-300"/></div>
            )}
            <input type="file" accept="image/*" onChange={handleImage} className="text-sm file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-green-100 file:text-green-700 hover:file:bg-green-200 cursor-pointer" />
          </div>
        </div>

        <button type="submit" className="w-full bg-green-700 text-white py-4 rounded-xl font-bold text-lg hover:bg-green-800 shadow-md">Save Record</button>
      </form>
    </div>
  );
}
