"use client"

import { useState } from 'react';
import { createProject, searchEquipment } from '@/lib/actions';
import { Plus, X, Search } from 'lucide-react';

export default function NewProject() {
  const[name, setName] = useState('');
  const [empName, setEmpName] = useState('');
  const[employees, setEmployees] = useState<string[]>([]);
  const [equipments, setEquipments] = useState<{ id: string, name: string, code: string }[]>([]);
  
  const[modalOpen, setModalOpen] = useState(false);
  const [search, setSearch] = useState('');
  const[searchResults, setSearchResults] = useState<any[]>([]);

  const addEmployee = () => {
    if (empName.trim()) {
      setEmployees([...employees, empName.trim()]);
      setEmpName('');
    }
  };

  const handleSearch = async (val: string) => {
    setSearch(val);
    if (val.length > 1) {
      const res = await searchEquipment(val);
      setSearchResults(res);
    } else {
      setSearchResults([]);
    }
  };

  const addEquipment = (eq: any) => {
    if (!equipments.find(e => e.id === eq.id)) {
      setEquipments([...equipments, eq]);
    }
    setModalOpen(false);
    setSearch('');
  };

  return (
    <div className="max-w-2xl mx-auto bg-white p-8 rounded-2xl shadow-sm border border-green-100">
      <h1 className="text-2xl font-bold text-green-900 mb-6 border-b border-green-50 pb-4">Initialize New Project</h1>
      
      <form action={() => createProject({ name, employees, equipmentIds: equipments.map(e => e.id) })} className="space-y-6">
        <div>
          <label className="block text-sm font-semibold text-green-800 mb-2">Project Name</label>
          <input required value={name} onChange={e => setName(e.target.value)} className="w-full border-green-200 focus:ring-green-600 focus:border-green-600 rounded-xl p-3 bg-green-50/50" placeholder="e.g. Lagos Lagoon Cleanup" />
        </div>

        <div>
          <label className="block text-sm font-semibold text-green-800 mb-2">Assigned Employees</label>
          <div className="flex gap-2 mb-3">
            <input value={empName} onChange={e => setEmpName(e.target.value)} className="flex-1 border-green-200 focus:ring-green-600 rounded-xl p-3 bg-green-50/50" placeholder="Employee Name" />
            <button type="button" onClick={addEmployee} className="bg-green-600 text-white px-4 rounded-xl hover:bg-green-700 transition"><Plus size={20}/></button>
          </div>
          <div className="flex flex-wrap gap-2">
            {employees.map((emp, i) => (
              <span key={i} className="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm flex items-center gap-1">
                {emp} <X size={14} className="cursor-pointer" onClick={() => setEmployees(employees.filter((_, idx) => idx !== i))} />
              </span>
            ))}
          </div>
        </div>

        <div>
          <label className="block text-sm font-semibold text-green-800 mb-2">Assigned Equipment</label>
          <button type="button" onClick={() => setModalOpen(true)} className="w-full py-4 border-2 border-dashed border-green-300 rounded-xl text-green-600 font-medium hover:bg-green-50 transition flex justify-center items-center gap-2">
            <Plus size={20}/> Assign Equipment
          </button>
          <div className="mt-4 space-y-2">
            {equipments.map((eq, i) => (
              <div key={i} className="flex justify-between bg-white border border-green-100 p-3 rounded-lg shadow-sm">
                <span className="font-medium text-green-900">{eq.name || 'Unnamed'} ({eq.code})</span>
                <X size={18} className="text-red-400 cursor-pointer" onClick={() => setEquipments(equipments.filter((_, idx) => idx !== i))} />
              </div>
            ))}
          </div>
        </div>

        <button type="submit" className="w-full bg-green-700 text-white py-4 rounded-xl font-bold text-lg hover:bg-green-800 shadow-md transition-all">Create Project</button>
      </form>

      {/* Equipment Modal */}
      {modalOpen && (
        <div className="fixed inset-0 bg-green-950/40 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
          <div className="bg-white p-6 rounded-2xl w-full max-w-md shadow-2xl">
            <div className="flex justify-between items-center mb-4">
              <h3 className="text-lg font-bold text-green-900">Search Equipment</h3>
              <X size={24} className="cursor-pointer text-gray-400 hover:text-green-700" onClick={() => setModalOpen(false)} />
            </div>
            <div className="relative mb-4">
              <Search className="absolute left-3 top-3.5 text-green-500" size={18} />
              <input value={search} onChange={e => handleSearch(e.target.value)} autoFocus className="w-full pl-10 pr-4 py-3 border-green-200 rounded-xl bg-green-50 focus:ring-green-600" placeholder="Type name or code..." />
            </div>
            <div className="max-h-60 overflow-y-auto space-y-2">
              {searchResults.map(res => (
                <div key={res.id} onClick={() => addEquipment(res)} className="p-3 bg-white border border-green-100 rounded-lg cursor-pointer hover:bg-green-50 flex justify-between">
                  <span className="font-semibold text-green-900">{res.name}</span>
                  <span className="text-xs font-mono bg-green-100 text-green-800 px-2 py-1 rounded">{res.code}</span>
                </div>
              ))}
              {search.length > 1 && searchResults.length === 0 && <p className="text-sm text-center text-gray-500">No equipment found.</p>}
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
