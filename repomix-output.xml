import prisma from '@/lib/db';
import { format } from 'date-fns';
import { CheckCircle2, XCircle } from 'lucide-react';

export const dynamic = 'force-dynamic';

export default async function HistoryPage() {
  const pastProjects = await prisma.project.findMany({
    where: { status: 'ENDED' },
    include: { employees: true, equipment: { include: { equipment: true } } },
    orderBy: { endDate: 'desc' }
  });

  return (
    <div>
      <div className="mb-8">
        <h1 className="text-3xl font-bold text-green-900">Project History</h1>
        <p className="text-green-700 mt-2">Archive of completed environmental deployments.</p>
      </div>

      <div className="space-y-6">
        {pastProjects.map(proj => (
          <div key={proj.id} className="bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-green-100 relative overflow-hidden">
            <div className="absolute top-0 left-0 w-1.5 h-full bg-gray-400" />
            
            <div className="flex flex-col md:flex-row md:justify-between md:items-start gap-4 mb-6">
              <div>
                <h2 className="text-2xl font-extrabold text-green-950 mb-1">{proj.name}</h2>
                <p className="text-sm text-green-600 font-medium">
                  {format(proj.startDate, 'MMM dd, yyyy')} — {proj.endDate ? format(proj.endDate, 'MMM dd, yyyy') : 'N/A'}
                </p>
              </div>
              <div className="bg-gray-50 border border-gray-200 px-4 py-2 rounded-xl text-right">
                <p className="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">Ended By</p>
                <p className="text-gray-800 font-semibold">{proj.endedBy}</p>
              </div>
            </div>

            <div className="grid md:grid-cols-2 gap-8 border-t border-green-50 pt-6">
              <div>
                <h3 className="text-xs uppercase tracking-widest text-green-500 font-bold mb-3">Assigned Staff</h3>
                <div className="flex flex-wrap gap-2">
                  {proj.employees.map(emp => (
                    <span key={emp.id} className="bg-green-50 text-green-800 px-3 py-1.5 rounded-lg text-sm font-medium border border-green-100">{emp.name}</span>
                  ))}
                </div>
              </div>

              <div>
                <h3 className="text-xs uppercase tracking-widest text-green-500 font-bold mb-3">Equipment Manifest</h3>
                <ul className="space-y-2">
                  {proj.equipment.map(eq => (
                    <li key={eq.id} className="flex items-center justify-between bg-white border border-green-100 p-2.5 rounded-xl shadow-sm">
                      <div>
                        <span className="font-semibold text-green-900 text-sm">{eq.equipment.name}</span>
                        <span className="ml-2 text-xs font-mono text-gray-500">{eq.equipment.code}</span>
                      </div>
                      <div className="flex items-center gap-1.5" title={eq.returned ? "Returned" : "Unaccounted"}>
                        {eq.returned ? (
                          <><CheckCircle2 size={18} className="text-green-500" /><span className="text-xs text-green-600 font-bold">Returned</span></>
                        ) : (
                          <><XCircle size={18} className="text-red-400" /><span className="text-xs text-red-500 font-bold">Pending</span></>
                        )}
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
        {pastProjects.length === 0 && (
          <div className="text-center py-20 bg-white rounded-3xl border border-green-100 border-dashed">
            <h3 className="text-xl font-bold text-green-800">No Past Projects</h3>
            <p className="text-green-600">Ended projects will appear here.</p>
          </div>
        )}
      </div>
    </div>
  );
}
