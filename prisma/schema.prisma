generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id        String              @id @default(uuid())
  name      String
  startDate DateTime            @default(now())
  endDate   DateTime?
  endedBy   String?
  status    String              @default("ONGOING") // ONGOING, ENDED
  employees Employee[]
  equipment AssignedEquipment[]
}

model Employee {
  id         String    @id @default(uuid())
  name       String
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  joinDate   DateTime  @default(now())
  status     String    @default("ASSIGNED") // ASSIGNED, RECALLED
  recallDate DateTime?
}

model Equipment {
  id          String               @id @default(uuid())
  name        String?
  code        String               @unique
  picture     String?
  components  EquipmentComponent[]
  assignments AssignedEquipment[]
}

model EquipmentComponent {
  id            String    @id @default(uuid())
  componentCode String    @unique
  equipmentCode String
  picture       String?
  equipment     Equipment @relation(fields:[equipmentCode], references: [code], onDelete: Cascade)
}

model AssignedEquipment {
  id          String    @id @default(uuid())
  projectId   String
  equipmentId String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  assignDate  DateTime  @default(now())
  status      String    @default("ASSIGNED") // ASSIGNED, RETURNED, MISSING, RECALLED
  recalledBy  String?
  recallDate  DateTime?
}